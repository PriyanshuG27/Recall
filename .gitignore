# =============================================================
# Recall — .gitignore
# =============================================================

# ----------------------------------------------------------------
# SECRETS & ENVIRONMENT — NEVER COMMIT
# ----------------------------------------------------------------
.env
.env.*
!.env.example
!.env.local.example
*.env
.envrc
secrets/
cookies.json           # Scraping cookies — gitignored explicitly

# ----------------------------------------------------------------
# PYTHON
# ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
pip-wheel-metadata/
.pytype/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Pytest
.pytest_cache/
.coverage
coverage.xml
coverage/
frontend/coverage/
htmlcov/
*.cover
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ----------------------------------------------------------------
# NODE / FRONTEND
# ----------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity

# Build output
frontend/dist/
frontend/build/
.vite/
*.local

# ----------------------------------------------------------------
# MODAL (Serverless GPU)
# ----------------------------------------------------------------
.modal/
modal.toml

# ----------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------
*.sql.bak
*.dump
backup_*.json
backup_*.json.gz
*.db
*.sqlite
*.sqlite3

# ----------------------------------------------------------------
# SECURITY REPORTS (contain vulnerability info — internal only)
# ----------------------------------------------------------------
security_reports/
# Note: SECURITY_SCAN_REPORT.md in docs/ IS committed (summary only)
# But raw tool outputs (bandit JSON, pip-audit JSON) are not

# ----------------------------------------------------------------
# LOGS
# ----------------------------------------------------------------
*.log
logs/
log/
smoke_test_report_*.json

# ----------------------------------------------------------------
# OS FILES
# ----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V3
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------
# EDITORS / IDEs
# ----------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.vim/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----------------------------------------------------------------
# TEMPORARY FILES
# ----------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.pid

# ----------------------------------------------------------------
# AUDIO / VIDEO (downloaded by yt-dlp — never commit)
# ----------------------------------------------------------------
*.ogg
*.mp3
*.mp4
*.wav
*.webm
*.m4a

# ----------------------------------------------------------------
# CHROME EXTENSION (built output)
# ----------------------------------------------------------------
frontend/extension/dist/

# ----------------------------------------------------------------
# KEEP THESE (important to not accidentally exclude)
# ----------------------------------------------------------------
# docs/               ← committed (all .md files)
# backend/modal_apps/ ← committed (Modal Python scripts)
# .env.example        ← committed (template, no values)

# Generated PDFs
docs/*.pdf

# Generated HTML viewers (built from .md — not source)
docs/PROMPTS.html
docs/prompts.html

# Personal build playbook — not for contributors
docs/PROMPTS.md
docs/PROMPTS.md.bak

# Generated intermediate data files
docs/prompts_data.json

# One-off tooling / build scripts (not part of the project source)
docs/reorganize_prompts.py
docs/parse_prompts.py
docs/generate_prompts_html.py

# Agent Workspace Directories
brain/
convo_history/
.agents/

# Local task, planning, and verification files
walkthrough.md
implementation_plan.md
manual_verification_suite.md
task.md
.coveragerc
fastapi_flow.png
fastapi_guide.pdf

# Local test data and helper generation scripts
test_data/
scripts/

# Private Backups & Decrypted Datasets — NEVER COMMIT
Recall Backup.md
Recall Decrypted.md
*.zip
*.mp4

# Benchmark & Audit Reports
k6_*_results.json
frontend/lh-*.json
test-results/
playwright-report/

# Temporary Text Dumps & Extracted Files
Advanced_Async_Programming_in_Python_*.md
Image__This_image_is_a_screenshot_of_a_LinkedIn_po_*.md
docs_summary.txt

# Internal Documentation & Historical Artifacts
docs/archive/
docs/prompts/
docs/internal/
Next version/
.next/

# Local performance baseline profiling data
deployment_profile.json
deployment_profile.csv
remote_ai_deployment_profile.json
