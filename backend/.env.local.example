# --- ENCRYPTION KEYS (Development Only - Do NOT use in production) ---
# FERNET_KEY: Must be a 32-byte URL-safe base64 key
FERNET_KEY="yF4P-W965hF17Bq_Q7g_oG5l8S631P9_9z-d8v7d8sA="
# JWT_SECRET: Minimum 32 hex characters (64 hex characters recommended)
JWT_SECRET="8a7b6c5d4e3f2a1b0c9d8e7f6a5b4c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b"

# --- VECTOR SEARCH OVERRIDE & AI CASCADE ---
# Pin provider to groq for local dev to avoid Modal GPU cold starts / costs
