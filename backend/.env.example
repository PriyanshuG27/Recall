# ==============================================================================
# RECALL - ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================
# INSTRUCTIONS:
# Copy this file to '.env' (for production/staging) or '.env.local' (for dev).
# Do NOT commit filled .env files to git.
# ==============================================================================

# --- DATABASE ---
# Neon PostgreSQLpooled connection string (must include ?sslmode=require)
DATABASE_URL=""

# --- TELEGRAM BOT ---
# Telegram Bot API token obtained from @BotFather (keep secret)
TELEGRAM_BOT_TOKEN=""

# --- ENCRYPTION KEYS ---
# Fernet symmetric key (generate with cryptography.fernet.Fernet.generate_key().decode())
FERNET_KEY=""
# Secret key for JWT signing (generate using a secure random hex string)
JWT_SECRET=""

# --- COMPUTE PROVIDER OVERRIDES (Optional) ---
# Override Cascade Tier. Options: groq, gemini, modal
COMPUTE_PROVIDER=""

# --- UPSTASH REDIS REST ---
# REST endpoint URL from Upstash Console
UPSTASH_REDIS_REST_URL=""
# REST authentication token from Upstash Console
UPSTASH_REDIS_REST_TOKEN=""

# --- AI PROVIDERS & API KEYS ---
# Modal token to execute serverless GPU applications
MODAL_API_TOKEN=""
# API key for Groq Cloud
GROQ_API_KEY=""
# API key for Google Gemini (Google AI Studio)
GEMINI_API_KEY=""
# API token for Hugging Face serverless Inference API (embedding failsafe)
HF_TOKEN=""

# --- WEB DASHBOARD / REDIRECTS ---
# Base URL where the React frontend dashboard is hosted
WEBSITE_URL=""

# --- GOOGLE DRIVE OAUTH (drive.file & drive.readonly scopes) ---
# Google Cloud Console client ID for OAuth
GOOGLE_CLIENT_ID=""
# Google Cloud Console client secret for OAuth
GOOGLE_CLIENT_SECRET=""
# OAuth callback URL registered in GCP (e.g., https://api.yourdomain.com/auth/google/callback)
GOOGLE_REDIRECT_URI=""

# --- FRONTEND COMPANION VARIABLES ---
# Base API URL of the FastAPI backend (for frontend references)
VITE_API_URL=""
# Username of the Telegram bot (without the '@', e.g. RecallBot)
VITE_BOT_USERNAME=""

# --- OPTIONAL: Self-hosted Cobalt instance for Instagram Reel downloads ---
# Deploy cobalt free on Railway/Render. Leave blank to skip Cobalt and go straight to yt-dlp.
COBALT_API_URL=""
# Optional: API key for authenticated access to your self-hosted Cobalt instance
COBALT_API_KEY=""

# --- OPTIONAL: Instagram Scraper & Cookies ---
# Instagram cookies encoded in base64 to bypass rate limits
IG_COOKIES_B64=""
# Browser used to extract local cookies (optional)
BROWSER_FOR_COOKIES=""

# --- ADDITIONAL AI PROVIDERS & TIERS ---
# OpenRouter API key for LLM calls
OPENROUTER_API_KEY=""
# NVIDIA API key for LLM calls
NVIDIA_API_KEY=""
# Cerebras API key for LLM calls
CEREBRAS_API_KEY=""

# --- INTERNAL WEBHOOK & API SECURITY ---
# Internal shared secret for API validation
INTERNAL_API_KEY="dev_internal_api_key"
# Telegram incoming webhook secret token
TELEGRAM_WEBHOOK_SECRET=""

# --- RERANKER & CONTEXTUAL RETRIEVAL CONFIGURATION ---
# Toggle SOTA cross-encoder reranking (True/False)
ENABLE_RERANKING="True"
# Preload reranker model on startup (True/False)
RERANK_PRELOAD_ON_STARTUP="True"
# Reranker provider (e.g. fastembed)
RERANKER_PROVIDER="fastembed"
# Frozen winner reranker model name
RERANKER_MODEL="Xenova/ms-marco-MiniLM-L-6-v2"
# Number of child candidates retrieved for first-stage hybrid search
RERANK_CANDIDATES="20"
# Number of top results returned after reranking
RERANK_TOP_N="5"
# Timeout in seconds for cross-encoder reranking inference
RERANK_TIMEOUT_SECONDS="2.0"

